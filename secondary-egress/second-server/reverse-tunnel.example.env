# Installed as /etc/reverse-tunnel.env by install.sh. Replace host, ports, and paths for your deployment.
TUNNEL_SSH_HOST=203.0.113.10
TUNNEL_SSH_PORT=22
TUNNEL_SSH_USER=root
TUNNEL_SSH_KEY=/root/.ssh/docker-host-tunnel

# Published on the Docker host (backup-runner: host.docker.internal:8021)
FTP_REMOTE_PORT=8021
FTP_LOCAL_PORT=21
# Must match vsftpd pasv_min_port / pasv_max_port
FTP_PASV_PORT_START=40000
FTP_PASV_PORT_END=40000

PROXY_REMOTE_PORT=18118
PROXY_LOCAL_PORT=8118

# Optional: expose a port on this server to a service on the Docker host (127.0.0.1, not container names)
TUNNEL_REVERSE_PORTS=8082:127.0.0.1:80
