# Host paths — all required; docker compose fails if any is unset.
# Defaults are created automatically by the bootstrap service on `docker compose up`.
SITES_DIR=
MARIADB_DATA_DIR=
LETSENCRYPT_DIR=
BACKUP_DIR=

# Shared MariaDB (one instance, separate database per site)
MARIADB_ROOT_PASSWORD=

# Shared backup runner (backup/sites.conf lists per-site paths)
# FTP target; optional base path after the port (e.g. host.docker.internal:8021/backups)
BACKUP_FTP_SERVER=
BACKUP_FTP_USER=
BACKUP_FTP_PASS=
# Leave empty when using inbound reverse tunnel (see secondary-egress/README.md).
BACKUP_FTP_PROXY=
BACKUP_FULL_HOUR=4

# Egress service via second server IP (SSH tunnel)
# outbound = Docker host SSHs to second server; inbound = second server SSHs to Docker host (one-way routing)
SECOND_IP_EGRESS_MODE=outbound
SECOND_IP_INBOUND_PROXY_HOST=host.docker.internal
SECOND_IP_INBOUND_PROXY_PORT=18118
# Example host uses RFC 5737 documentation address — replace with your second server.
SECOND_IP_SSH_HOST=198.51.100.20
# Second server sshd Port — set your real value in .env on the Docker host (do not commit).
SECOND_IP_SSH_PORT=22
SECOND_IP_SSH_USER=
# Host path to SSH private key file (read-only mount into secondary-egress)
SECOND_IP_SSH_KEY_PATH=

# Reverse forwards (outbound mode only). Inbound: set TUNNEL_REVERSE_PORTS in /etc/reverse-tunnel.env on the second server.
# Format: REMOTE_PORT or REMOTE_PORT:TARGET_HOST:TARGET_PORT
# Example: SECOND_IP_REVERSE_PORTS=8082:127.0.0.1:80
SECOND_IP_REVERSE_PORTS=
