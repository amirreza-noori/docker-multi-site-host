# Host paths — all required; docker compose fails if any is unset.
# Defaults are created automatically by the bootstrap service on `docker compose up`.
SITES_DIR=
MARIADB_DATA_DIR=
LETSENCRYPT_DIR=
BACKUP_DIR=

# Shared MariaDB (one instance, separate database per site)
MARIADB_ROOT_PASSWORD=

# Shared backup runner (backup/sites.conf lists per-site paths)
BACKUP_FTP_SERVER=
BACKUP_FTP_USER=
BACKUP_FTP_PASS=
BACKUP_FULL_HOUR=4

# Egress service via second server IP (SSH tunnel)
SECOND_IP_SSH_HOST=
SECOND_IP_SSH_PORT=22
SECOND_IP_SSH_USER=
# Host path to SSH private key file (read-only mount into secondary-egress)
SECOND_IP_SSH_KEY_PATH=

# Reverse forwards: target-server ports published back to services on the main side.
# Space/comma separated list; each entry is "REMOTE_PORT" or "REMOTE_PORT:TARGET_HOST:TARGET_PORT".
# Missing target host/port default to host.docker.internal:REMOTE_PORT. Empty disables it.
# Requires GatewayPorts yes (or clientspecified) on the target sshd for public access.
# Example: SECOND_IP_REVERSE_PORTS=8081 8082:haproxy:80
SECOND_IP_REVERSE_PORTS=
